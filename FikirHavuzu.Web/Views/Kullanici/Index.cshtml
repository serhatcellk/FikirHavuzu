@model List<FikirHavuzu.Entities.Kullanici>

@{
    ViewData["Title"] = "Kullanıcılar";
}

<h2>Kullanıcılar</h2>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width:400px;">
        <input type="text" name="arama" value="@ViewBag.Arama" class="form-control" placeholder="İsim veya mail ara..." />
        <button type="submit" class="btn btn-primary">Ara</button>
        <a asp-action="Index" class="btn btn-secondary">Temizle</a>
    </div>
</form>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Ekle" class="btn btn-primary mb-3">Yeni Kullanıcı</a>
}

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Mail</th>
            <th>Telefon</th>
            <th>Sicil No</th>
            <th>TC Kimlik No</th>
            <th>Durum</th>
            @if (User.IsInRole("Admin"))
            {
                <th>İşlem</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.Ad</td>
                <td>@k.Soyad</td>
                <td>@k.MailAdresi</td>
                <td>@k.TelefonNumarasi</td>
                <td>@k.SicilNumarasi</td>
                <td>@k.TCKimlikNumarasi</td>
                <td>@(k.AktifMi ? "Aktif" : "Pasif")</td>
                @if (User.IsInRole("Admin"))
                {
                    <td>
                        <a asp-action="Duzenle" asp-route-id="@k.Id" class="btn btn-sm btn-info">Düzenle</a>
                        @if (k.AktifMi)
                        {
                            <a asp-action="PasifeAl" asp-route-id="@k.Id" class="btn btn-sm btn-warning">Pasife Al</a>
                        }
                        else
                        {
                            <a asp-action="AktifeAl" asp-route-id="@k.Id" class="btn btn-sm btn-success">Aktife Al</a>
                        }
                        <a asp-controller="Yetki" asp-action="Ata" asp-route-kullaniciId="@k.Id" class="btn btn-sm btn-secondary">Yetkiler</a>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>